{
  "name": "gpt-image-viewer",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:debug": "tsc --noEmit && vite build --sourcemap",
    "generate:icons": "node scripts/generate-icons.mjs",
    "package": "npm run generate:icons && npm run build && node scripts/package-extension.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
