{
  "manifest_version": 3,
  "name": "GPT Image Viewer",
  "version": "0.4.0",
  "description": "Capture and review ChatGPT image metadata locally.",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GPT Image Viewer"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://chatgpt.com https://chat.openai.com; img-src 'self' https://chatgpt.com https://chat.openai.com data: blob;"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["assets/content-script.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["assets/page-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "clipboardWrite",
    "downloads",
    "sidePanel",
    "scripting",
    "storage"
  ],
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "minimum_chrome_version": "116"
}
